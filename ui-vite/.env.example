# Environment Variables Template
# Copy this file to `.env.local` for local development
# Copy this file to `.env.production` for production builds

# =============================================================================
# API Configuration
# =============================================================================
# Base URL for backend API
VITE_API_BASE_URL=http://127.0.0.1:8000

# =============================================================================
# Logging Configuration
# =============================================================================
# Log level: debug | info | warn | error
VITE_LOG_LEVEL=debug

# =============================================================================
# Telemetry Configuration
# =============================================================================
# Enable/disable telemetry reporting
VITE_ENABLE_TELEMETRY=false

# Telemetry endpoint (leave empty to disable)
VITE_TELEMETRY_ENDPOINT=

# =============================================================================
# Request Configuration
# =============================================================================
# Default timeout for admin API requests (ms)
VITE_ADMIN_REQUEST_TIMEOUT_MS=10000

# =============================================================================
# Feature Flags
# =============================================================================
# Show debug UI components
VITE_ENABLE_DEBUG_UI=true

# =============================================================================
# Cache Version Identifiers
# =============================================================================
# Bump VITE_PROMPT_VERSION whenever score_analytics.txt is edited.
# Bump VITE_ENGINE_VERSION whenever the backend explain engine is upgraded.
# Both values are baked into the cache key at build time.
# Any change invalidates all existing client-side cached explain responses.
VITE_PROMPT_VERSION=score_analytics_v1
VITE_ENGINE_VERSION=2.0.0

# =============================================================================
# Explain Cache Settings
# =============================================================================
# Set to 'false' to disable client-side response caching entirely.
VITE_EXPLAIN_ENABLE_CACHE=true
# TTL in milliseconds (default 300000 = 5 minutes).
# Fallback responses ignore this setting and are never cached.
VITE_EXPLAIN_MAX_CACHE_AGE=300000
