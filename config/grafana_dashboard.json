{
  "dashboard": {
    "id": null,
    "uid": "hdss-observability",
    "title": "HDSS Runtime Observability",
    "tags": ["hdss", "observability", "sre"],
    "timezone": "browser",
    "refresh": "15s",
    "time": { "from": "now-1h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "System CPU %",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [
          { "expr": "system_cpu_percent", "legendFormat": "CPU" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "System Memory %",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
        "targets": [
          { "expr": "system_memory_percent", "legendFormat": "Memory" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 85 },
                { "color": "red", "value": 95 }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Process RSS (MB)",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
        "targets": [
          { "expr": "process_rss_mb", "legendFormat": "RSS" }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 512 },
                { "color": "red", "value": 1024 }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Uptime",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "targets": [
          { "expr": "process_uptime_seconds", "legendFormat": "Uptime" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 5,
        "title": "HTTP Request Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [
          { "expr": "rate(http_requests_total[5m])", "legendFormat": "req/s" },
          { "expr": "rate(http_errors_total[5m])", "legendFormat": "err/s" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" }
        }
      },
      {
        "id": 6,
        "title": "Error Rate",
        "type": "gauge",
        "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
        "targets": [
          {
            "expr": "rate(http_errors_total[5m]) / rate(http_requests_total[5m])",
            "legendFormat": "Error %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.01 },
                { "color": "red", "value": 0.05 }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Health Status",
        "type": "stat",
        "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
        "targets": [
          { "expr": "health_status", "legendFormat": "Health" }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "UNHEALTHY", "color": "red" } } },
              { "type": "value", "options": { "0.5": { "text": "DEGRADED", "color": "yellow" } } },
              { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" } } }
            ]
          }
        }
      },
      {
        "id": 8,
        "title": "HTTP Request Latency (p50 / p95 / p99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "p99"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 9,
        "title": "Scoring Engine Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(scoring_duration_seconds_bucket[5m]))",
            "legendFormat": "Scoring p95"
          },
          {
            "expr": "rate(scoring_duration_seconds_count[5m])",
            "legendFormat": "Scoring rate"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 10,
        "title": "Data Drift",
        "type": "stat",
        "gridPos": { "h": 6, "w": 8, "x": 0, "y": 22 },
        "targets": [
          { "expr": "data_drift_score", "legendFormat": "Drift Score" },
          { "expr": "data_drift_detected", "legendFormat": "Drifted" }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Browser Leak Monitor",
        "type": "stat",
        "gridPos": { "h": 6, "w": 8, "x": 8, "y": 22 },
        "targets": [
          { "expr": "browser_memory_leak", "legendFormat": "Leak Detected" },
          { "expr": "browser_leak_severity", "legendFormat": "Severity" }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": {
                "0": { "text": "None", "color": "green" },
                "1": { "text": "Low", "color": "blue" },
                "2": { "text": "Medium", "color": "yellow" },
                "3": { "text": "High", "color": "orange" },
                "4": { "text": "Critical", "color": "red" }
              }}
            ]
          }
        }
      },
      {
        "id": 12,
        "title": "Pipeline Stage Duration",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 8, "x": 16, "y": 22 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(pipeline_stage_duration_seconds_bucket[5m]))",
            "legendFormat": "Stage p95"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" }
        }
      },
      {
        "id": 13,
        "title": "Recent Alerts",
        "type": "table",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
        "targets": [
          { "type": "api", "url": "/ops/alerts?hours=24" }
        ]
      }
    ]
  }
}
